# Copy to `.env.local` and fill in. Never commit real secrets.

# Airtable Personal Access Token (server-only). Create at airtable.com/create/tokens
# Scopes: data.records:read + data.records:write for base "librica-med-store"
AIRTABLE_PAT=

# Base ID from https://airtable.com/api — the id for base "librica-med-store"
AIRTABLE_BASE_ID=

# Optional: override default English table names if yours differ
# AIRTABLE_TABLE_BOOKS=books
# AIRTABLE_TABLE_SHIPPING=shipping_rules
# AIRTABLE_TABLE_ORDERS=orders

# --- Expected Airtable fields (names must match API field names) ---
#
# Table: books
#   title, slug, description, price_lkr, weight_grams,
#   cover_image (attachment or URL text), gallery_images (attachments),
#   status (active | inactive), featured (checkbox, optional)
#
# Table: shipping_rules
#   min_weight_grams, max_weight_grams (leave empty on top “and above” row),
#   price_lkr
#
# Table: orders
#   order_id, customer_name, phone_number, delivery_address,
#   cart_items_json, items_summary, total_weight_grams,
#   books_total_lkr, shipping_cost_lkr, grand_total_lkr,
#   order_status (pending | confirmed | packed | completed | cancelled),
#   created_at (ISO text recommended)
